{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devmanager-agent.local/schemas/score.schema.json",
  "title": "Score",
  "type": "object",
  "additionalProperties": false,
  "required": ["score_id", "run_id", "scoring_version", "status", "deductions", "created_at"],
  "properties": {
    "score_id": { "type": "string", "format": "uuid" },
    "run_id": { "type": "string", "format": "uuid" },
    "scoring_version": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["complete", "incomplete"] },
    "final_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "grade": { "type": ["string", "null"], "enum": ["A+", "A", "B", "C", "D", "F", null] },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "deductions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "category", "severity", "raw_deduction", "adjusted_deduction"],
        "properties": {
          "finding_id": { "type": "string" },
          "category": { "type": "string" },
          "severity": { "type": "string" },
          "raw_deduction": { "type": "number", "minimum": 0 },
          "adjusted_deduction": { "type": "number", "minimum": 0 },
          "cap_applied": { "type": ["string", "null"] }
        }
      }
    },
    "caps": { "type": "array", "items": { "type": "string" }, "default": [] },
    "limitations": { "type": "array", "items": { "type": "string" }, "default": [] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
