# Application
APP_ENV=local
APP_VERSION=0.1.0

# Database (asyncpg dialect for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:sinopharm%401089@localhost:5432/agent_devops
DATABASE_POOL_SIZE=5

# Object store (use file:// for local, s3:// for production)
OBJECT_STORE_URL=file:///tmp/devmanager-object-store

# Logging
LOG_LEVEL=info

# Anthropic / compatible API
# Auth: ANTHROPIC_AUTH_TOKEN takes priority over ANTHROPIC_API_KEY
# Use ANTHROPIC_AUTH_TOKEN for DeepSeek / proxy endpoints
# Use ANTHROPIC_API_KEY for official Anthropic API
# ANTHROPIC_AUTH_TOKEN=<your-deepseek-or-proxy-key>
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model — defaults to claude-opus-4-8; set to compatible model name for proxies
# Official:  claude-opus-4-8
# DeepSeek:  deepseek-v4-pro[1m]
ANTHROPIC_MODEL=claude-opus-4-8

# Base URL — leave unset for official https://api.anthropic.com
# DeepSeek:  https://api.deepseek.com/anthropic
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Policy / scoring versioning
POLICY_VERSION=v1
SCORING_VERSION=v1

# API security (change in production)
API_SECRET_KEY=change-me-in-production

# Redis (for ARQ async task queue)
# Leave unset to disable background jobs (webhook will still create runs, but won't enqueue)
REDIS_URL=redis://localhost:6379

# GitHub Webhook secret (HMAC-SHA256)
# Leave unset to skip signature verification (local dev only)
# Set via: Settings → Webhooks → Secret in your GitHub repo
GITHUB_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# S4 Team Operations — PM (自研需求平台) integration
# ─────────────────────────────────────────────────────────────────────

# Base URL of the in-house requirements platform REST API.
# No trailing slash. Required for any sync job to start.
PM_API_BASE_URL=

# Bearer token for PM API. Required. Do NOT hardcode — keep in .env / secrets manager.
PM_API_TOKEN=

# HTTP request timeout in seconds. Default 30.
PM_API_TIMEOUT_SECONDS=30

# Pagination page size when listing iterations / issues / users. Default 100.
PM_API_PAGE_SIZE=100

# Toggle for the (currently disabled) PM webhook receiver. v1: leave "false".
# When true, /v1/webhooks/pm is exposed. See services/pm-integration/devmanager_pm_integration/webhook.py.
PM_WEBHOOK_ENABLED=false

# ─────────────────────────────────────────────────────────────────────
# S4 Team Operations — GitLab webhook (for MR / review / approval events)
# ─────────────────────────────────────────────────────────────────────

# HMAC-SHA256 secret configured in GitLab project settings → Webhooks.
# Required for production. Local dev may leave blank to skip verification.
GITLAB_WEBHOOK_SECRET=
